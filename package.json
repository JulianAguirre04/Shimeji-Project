{
  "name": "kirby-pet",
  "version": "1.0.0",
  "description": "Kirby desktop pet",
  "author": "Julian Aguirre",
  "main": "Main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.yourname.kirbypet",
    "productName": "Kirby Pet",
    "extends": null,
    "win": {
      "target": "nsis",
      "icon": "assets/Icon/kirby_puter.ico"
    },

    "mac": {
      "target": "dmg",
      "icon": "assets/Kirby_icon.png"
    },
    
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "Main.js",
      "src/**/*",
      "assets/**/*",
      "package.json",
      "!**/*.kra",
      "!**/*.log",
      "!node_modules/.cache"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}